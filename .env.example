# Flask Configuration
FLASK_ENV=production
FLASK_APP=src/app.py
DEBUG=False

# Model Configuration
MODEL_PATH=models/rf_model_v2.pkl
ENCODER_PATH=models/label_encoder.pkl
AUTO_DOWNLOAD_MODELS=false
MODEL_URL=
ENCODER_URL=
MODEL_DOWNLOAD_TIMEOUT=120

# Optional: host model files in cloud storage or GitHub Releases
# and provide direct download URLs via MODEL_URL and ENCODER_URL.

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Security
LOG_LEVEL=INFO
MAX_URL_LENGTH=2000
